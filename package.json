{
  "name": "punchlist-launch",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:desktop": "npx playwright test --project=desktop-chrome",
    "test:e2e:mobile": "npx playwright test --project=mobile-iphone",
    "test:e2e:report": "npx playwright show-report",
    "test:visual": "npx playwright test tests/v100-visual.spec.ts",
    "test:visual:update": "npx playwright test tests/v100-visual.spec.ts --update-snapshots",
    "test:perf": "npx playwright test tests/v100-perf.spec.ts --project=desktop-chrome",
    "test:a11y": "npx playwright test tests/v100-a11y.spec.ts --project=desktop-chrome",
    "smoke": "bash deploy-scripts/smoke-test.sh"
  },
  "dependencies": {
    "@stripe/stripe-js": "^5.5.0",
    "@supabase/supabase-js": "^2.57.4",
    "papaparse": "^5.4.1",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.10.2",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.21"
  }
}
